{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AgentArmor Studio",
  "version": "0.1.0",
  "identifier": "com.agentarmor.studio",
  "build": {
    "beforeDevCommand": "npm run -- vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run -- vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "AgentArmor Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/agentarmor-sidecar-x86_64-pc-windows-msvc.exe"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/installer.ico",
        "headerImage": "icons/header.bmp",
        "displayLanguageSelector": false,
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://releases.agentarmor.dev/{{target}}/{{arch}}/latest.json"
      ],
      "pubkey": "REPLACE_WITH_YOUR_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
